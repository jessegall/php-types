{
    "name": "jessegall/php-types",
    "description": "Named typed constants and predicates — give meaning to magic literals like '', [], '{}', 0, true and null.",
    "keywords": [
        "php",
        "types",
        "constants",
        "value-objects",
        "predicates"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jesse Gall",
            "email": "jessegall@example.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "JesseGall\\PhpTypes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JesseGall\\PhpTypes\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/phpunit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "JesseGall\\PhpTypes\\PhpTypesServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
